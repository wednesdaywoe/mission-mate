{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MissionMate",
  "version": "0.1.0",
  "identifier": "com.haulerhelper.missionmate",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Mission Mate",
        "width": 520,
        "height": 660,
        "minWidth": 420,
        "minHeight": 480,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/mission-mate"]
  }
}
